        </w:rPr>
        <w:t>LMS Class Management Process Flow</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="3C4EF180">
      <w:r>
        <w:t>This document outlines the proposed operational process flow for the LMS (Learning Management System) focused on class management, mentor allocation, scheduling, and student booking workflows.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="63D8F2D0">
      <w:pPr>
        <w:pStyle w:val="3"/>
      </w:pPr>
      <w:r>
        <w:t>1. Super Admin Management</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="54F338D1">
      <w:pPr>
        <w:pStyle w:val="23"/>
      </w:pPr>
      <w:r>
        <w:t>Create and manage admin accounts</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="64EA4C23">
      <w:pPr>
        <w:pStyle w:val="23"/>
      </w:pPr>
      <w:r>
        <w:t>Create mentor profiles and assign permissions</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="7589777A">
      <w:pPr>
        <w:pStyle w:val="23"/>
      </w:pPr>
      <w:r>
